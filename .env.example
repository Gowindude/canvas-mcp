# Copy this file to ".env" and fill in your own values.
# The .env file is git-ignored and must never be committed.

# A Canvas API access token. Generate one from:
#   Canvas -> Account -> Settings -> Approved Integrations -> + New Access Token
# See the README for detailed, step-by-step instructions.
CANVAS_API_TOKEN=your_token_here

# The base URL of your institution's Canvas instance (no trailing /api/v1).
# Example for Georgia Tech:
CANVAS_BASE_URL=https://gatech.instructure.com
